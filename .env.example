# FastAPI Starter — environment configuration
# Copy this file to .env and adjust values:
#   cp .env.example .env
#
# Settings are read by app/config.py.
# Unset variables fall back to the Python defaults below.

# Port the FastAPI server listens on.
# Default: 8000
PORT=8000

# URL prefix for all API routes.
# Default: /api
API_PREFIX=/api
