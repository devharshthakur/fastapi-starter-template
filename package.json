{
  "name": "fastapi-starter-template",
  "version": "1.4.0",
  "description": "A lean fastapi starter template",
  "type": "module",
  "scripts": {
    "dev": "uv run python scripts/serve.py --dev",
    "start": "uv run python scripts/serve.py",
    "lint": "uv run ruff check . && prettier --check .",
    "format": "uv run ruff format . && prettier --write .",
    "typecheck": "uv run ty check",
    "test": "uv run pytest",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "docker:build": "docker compose build",
    "docker:rebuild": "docker compose build --no-cache",
    "docker:start": "docker compose up -d",
    "docker:stop": "docker compose stop",
    "docker:clean": "docker compose down",
    "prepare": "husky"
  },
  "keywords": [],
  "author": {
    "name": "Harsh Thakur",
    "email": "harshprojects2002@outlook.com",
    "url": "https://github.com/devharshthakur"
  },
  "packageManager": "pnpm@11.7.0",
  "license": "MIT",
  "devDependencies": {
    "changelogen": "^0.6.2",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-toml": "^2.0.6"
  }
}
